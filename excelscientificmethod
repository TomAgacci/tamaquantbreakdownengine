D1 = 1 + A1
E1 = -A1 * C1
F1 = B1
G1 = E1^2 - 4*D1*F1   (discriminant)
H1 = (-E1 + SQRT(G1)) / (2*D1)   (x*)
I1 = C1 - H1                      (y*)
J1 = H1 * I1                      (z*)

K1 = H1 + 0.001
L1 = I1 + 0.001
M1 = (A1*L1 - B1/K1) + (C1 - K1)   (T(x+ε,y+δ))

N1 = ABS(M1)
O1 = N1 <= 0.000001   (TRUE = accepted)
